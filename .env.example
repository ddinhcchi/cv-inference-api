# Inference device: mps (Apple Silicon), cuda, or cpu
DEVICE=cpu

# Model weights path or name (YOLOv8 nano/small/medium etc.)
MODEL_WEIGHTS=yolov8n.pt

# Default confidence threshold (clients can override per request)
DEFAULT_CONF=0.4

# Max image side after resize (keeps memory bounded for huge uploads)
MAX_IMAGE_SIDE=1920

# Optional API key — if set, requests must send `X-API-Key: <value>` header
API_KEY=

# Comma-separated allowed origins for CORS, or * for any
ALLOWED_ORIGINS=*
